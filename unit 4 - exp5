import numpy as np

prices = np.linspace(1, 10, 10)

def demand(price):
    return max(0, 20 - 2 * price + np.random.randn())

best_profit = -1
best_price = 0

for p in prices:
    d = demand(p)
    profit = p * d

    if profit > best_profit:
        best_profit = profit
        best_price = p

print("Best Price:", best_price)
print("Max Profit:", best_profit)
