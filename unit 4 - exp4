import numpy as np
from sklearn.linear_model import LinearRegression

# Synthetic data
X = np.random.rand(100, 3)  # portfolios
y = X @ np.array([2, 3, 1]) + np.random.randn(100)

model = LinearRegression()
model.fit(X, y)

# Test portfolios
test = np.array([[0.3, 0.5, 0.2],
                 [0.6, 0.2, 0.2]])

pred = model.predict(test)

print("Predicted Returns:", pred)
